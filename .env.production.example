# Copy to .env on your VPS:  cp .env.production.example .env
# Never commit .env with real secrets.

# --- Required: strong DB password (must match POSTGRES_PASSWORD in compose) ---
POSTGRES_PASSWORD=change-me-use-openssl-rand-hex-32
DATABASE_URL=postgresql://postgres:change-me-use-openssl-rand-hex-32@timescaledb:5432/ploy_agent

# Dashboard bind (VPS/Cloudflare: 127.0.0.1; AWS uses docker-compose.aws.yml → 0.0.0.0)
WEB_HOST=127.0.0.1
WEB_PORT=8765

# Polymarket — World Cup game events (fifwc-* via soccer-fifwc series)
POLY_GAMMA_TAGS=soccer,fifa-world-cup
POLY_GAMMA_SERIES_SLUGS=soccer-fifwc
POLY_GAMMA_DISCOVERY_LIMIT=500
POLY_GAMMA_EVENT_SLUGS=
ENRICHMENT_ENABLED=false
AGENT_STRATEGIES=book_imbalance,cross_venue_arb,consensus
KALSHI_ENABLED=true
KALSHI_POLL_INTERVAL_SEC=10
KALSHI_WC_GAME_SERIES=KXWCGAME
CROSS_VENUE_MAP_MIN_CONFIDENCE=0.85
CROSS_VENUE_MAP_REVIEW_CONFIDENCE=0.60
CROSS_VENUE_POLY_EVENT_SLUG_PREFIX=fifwc
CROSS_VENUE_PAIRS_PATH=config/cross_venue/world_cup_pairs.yaml
RANK_TOP_N=10
RANK_MERGE_BY_MARKET=true
MIN_EDGE_CENTS=8.0
ENTRY_PRICE_MIN=0.40
ENTRY_PRICE_MAX=0.60
MIN_RISK_REWARD=0.40
CROSS_VENUE_MIN_EDGE_CENTS=8

# Reasoning (optional but recommended)
ANTHROPIC_API_KEY=

# Slack (optional)
SLACK_BOT_TOKEN=
SLACK_CHANNEL=
SLACK_EVENTS_PORT=8766

# Paper trading on VPS (sim-forward container)
SIM_FORWARD_INTERVAL_SEC=5
SIM_FORWARD_PROFILES=e8_c70_m65
# 0 = run until you stop the stack; 336 = auto-stop after 14 days; 48 = 2-day smoke test
SIM_FORWARD_RUN_HOURS=48
# Skip sim entries on markets resolving farther than N hours (0 = disabled; 48 for short-dated runs)
SIM_MAX_HOURS_TO_RESOLUTION=48
SIM_EDGE_PERSISTENCE_TICKS=3
SIM_EDGE_PERSISTENCE_MIN_SEC=30

# TLS: leave false on Linux VPS unless you hit cert errors
PLOY_INSECURE_SSL=false
