DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ploy_agent

# Dev only: if Python TLS fails on macOS (CERTIFICATE_VERIFY_FAILED), set to true — NOT for production
PLOY_INSECURE_SSL=false

# Polymarket (read is public; Gamma tag slugs or numeric ids, comma-separated)
GAMMA_BASE_URL=https://gamma-api.polymarket.com
CLOB_BASE_URL=https://clob.polymarket.com
POLY_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market
# Prefer POLY_GAMMA_TAGS; if empty, POLY_NBA_TAGS is used (backward compatible)
POLY_GAMMA_TAGS=nba
POLY_NBA_TAGS=nba
# Always ingest these Gamma event slugs (IPO, politics, etc.) in addition to tags
# POLY_GAMMA_EVENT_SLUGS=spacex-or-openai-higher-ipo-closing-market-cap,what-will-spacexs-ipo-valuation-be

# Enrichment (optional — off by default; enable with ENRICHMENT_ENABLED=true + compose profile sports)
ENRICHMENT_ENABLED=false
SPORTS_PROVIDER=espn
# ESPN path keys currently supported in code: nba, mlb, nfl, nhl, wnba
ENRICHMENT_ESPN_LEAGUES=nba,mlb,nfl,nhl,wnba
# The Odds API v4 sport keys when SPORTS_PROVIDER=odds
ENRICHMENT_ODDS_LEAGUES=basketball_nba,baseball_mlb,americanfootball_nfl,icehockey_nhl,basketball_wnba
ODDS_API_KEY=
ODDS_API_BASE=https://api.the-odds-api.com/v4

# Market categories (Gamma slug) where NBA logistic baseline + player_adjust run
BASELINE_MODEL_CATEGORIES=nba

# Strategies (comma-separated). Default: price-only + cross-venue arb (no ESPN/game_state).
# cross_venue_arb needs KALSHI_ENABLED=true and loaded cross_venue_pairs.
# consensus MUST be last if enabled.
AGENT_STRATEGIES=cross_venue_arb,cross_market_arb,book_imbalance
STALE_QUOTE_WINDOW_SEC=120
STALE_QUOTE_SCORE_SWING=10
STALE_QUOTE_PRICE_MOVE=0.015
SPORTSBOOK_SHARP_WEIGHTS=pinnacle:3,circa:3,draftkings:1,fanduel:1
SPORTSBOOK_REGIONS=us,eu
CROSS_MARKET_SUM_DEVIATION=0.04
BEHAVIOR_OVERREACTION_MULT=2.5
BEHAVIOR_PRICE_WINDOW_SEC=45
PLAYER_ADJUST_SCALE=0.004
RANK_MERGE_BY_MARKET=true

# Kalshi cross-venue (World Cup pairs in config/cross_venue/world_cup_pairs.yaml)
KALSHI_ENABLED=true
KALSHI_BASE_URL=https://api.elections.kalshi.com/trade-api/v2
KALSHI_POLL_INTERVAL_SEC=10
# Optional for WebSocket / signed REST (v1 uses public REST poll)
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=
POLY_FEE_RATE=0.02
KALSHI_FEE_RATE=0.01
CROSS_VENUE_MIN_EDGE_CENTS=8
CROSS_VENUE_MAX_STALE_SEC=30
CROSS_VENUE_MIN_DEPTH=500
CROSS_VENUE_PAIRS_PATH=config/cross_venue/world_cup_pairs.yaml
# POLY_GAMMA_TAGS=fifa,world-cup
# POLY_GAMMA_EVENT_SLUGS=

# Reasoning
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Shared log file (ingest / enrich / reason append here; dashboard shows a tail)
AGENT_LOG_FILE=artifacts/agent.log

# Paper-trading simulation (ploy-sim)
SIM_FORWARD_INTERVAL_SEC=5
# Forward: auto-stop after N hours (336 = 14 days; 0 = run until you stop it)
SIM_FORWARD_RUN_HOURS=336
# Paper sim: skip entries when end_date is unknown or > N hours out (0 = disabled)
SIM_MAX_HOURS_TO_RESOLUTION=0
# Replay: default lookback when --from is omitted
SIM_REPLAY_DAYS=14

# Web dashboard
WEB_HOST=127.0.0.1
WEB_PORT=8765

# Ranking service (persists recommendation rows; UI reads DB directly)
MIN_EDGE_CENTS=3.0
RANK_TOP_N=10

# Alert filters (optional — picks below these thresholds are silently dropped from Slack/Telegram)
# Set ALERT_MIN_EDGE=0 to use MIN_EDGE_CENTS as the floor
ALERT_MIN_EDGE=0
ALERT_MIN_DEPTH=0
ALERT_MIN_SCORE=0

# Slack (optional — leave empty to skip Slack posting)
# Bot scopes needed: chat:write, chat:update
# Interactivity Request URL: http://<your-host>:8766/slack/interactions
SLACK_BOT_TOKEN=
SLACK_CHANNEL=
SLACK_EVENTS_PORT=8766
