DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ploy_agent

# Dev only: if Python TLS fails on macOS (CERTIFICATE_VERIFY_FAILED), set to true — NOT for production
PLOY_INSECURE_SSL=false

# Polymarket (read is public; Gamma tag slugs or numeric ids, comma-separated)
GAMMA_BASE_URL=https://gamma-api.polymarket.com
CLOB_BASE_URL=https://clob.polymarket.com
POLY_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market
# Prefer POLY_GAMMA_TAGS; if empty, POLY_NBA_TAGS is used (backward compatible)
# High-activity starter set: NBA, MLB, NFL, NHL, WNBA
POLY_GAMMA_TAGS=nba,mlb,nfl,nhl,wnba
POLY_NBA_TAGS=nba

# Enrichment: espn (default, no key) or odds (needs ODDS_API_KEY)
SPORTS_PROVIDER=espn
# ESPN path keys currently supported in code: nba, mlb, nfl, nhl, wnba
ENRICHMENT_ESPN_LEAGUES=nba,mlb,nfl,nhl,wnba
# The Odds API v4 sport keys when SPORTS_PROVIDER=odds
ENRICHMENT_ODDS_LEAGUES=basketball_nba,baseball_mlb,americanfootball_nfl,icehockey_nhl,basketball_wnba
ODDS_API_KEY=
ODDS_API_BASE=https://api.the-odds-api.com/v4

# Market categories (Gamma slug) where NBA logistic baseline + player_adjust run
BASELINE_MODEL_CATEGORIES=nba

# Strategies (comma-separated): baseline_model, stale_quote, sportsbook_consensus,
# cross_market_arb, behavior_fade, player_adjust
AGENT_STRATEGIES=cross_market_arb,baseline_model,player_adjust
STALE_QUOTE_WINDOW_SEC=120
STALE_QUOTE_SCORE_SWING=10
STALE_QUOTE_PRICE_MOVE=0.015
SPORTSBOOK_SHARP_WEIGHTS=pinnacle:3,circa:3,draftkings:1,fanduel:1
SPORTSBOOK_REGIONS=us,eu
CROSS_MARKET_SUM_DEVIATION=0.04
BEHAVIOR_OVERREACTION_MULT=2.5
BEHAVIOR_PRICE_WINDOW_SEC=45
PLAYER_ADJUST_SCALE=0.004
RANK_MERGE_BY_MARKET=true

# Reasoning
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Shared log file (ingest / enrich / reason append here; dashboard shows a tail)
AGENT_LOG_FILE=artifacts/agent.log

# Web dashboard
WEB_HOST=127.0.0.1
WEB_PORT=8765

# Ranking service (persists recommendation rows; UI reads DB directly)
MIN_EDGE_CENTS=3.0
RANK_TOP_N=10

# Slack (optional — leave empty to skip Slack posting)
# Bot scopes needed: chat:write, chat:update
# Interactivity Request URL: http://<your-host>:8766/slack/interactions
SLACK_BOT_TOKEN=
SLACK_CHANNEL=
SLACK_EVENTS_PORT=8766
